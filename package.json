{
  "name": "magic-beans",
  "version": "1.0.0",
  "private": true,
  "description": "Magic Beans - crypto portfolio tracker. Modern rebuild (Vite + React + Mantine + Express + Drizzle).",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev --workspace=@magic-beans/server",
    "dev:client": "npm run dev --workspace=@magic-beans/client",
    "build": "npm run build --workspace=@magic-beans/shared && npm run build --workspace=@magic-beans/server && npm run build --workspace=@magic-beans/client",
    "db:generate": "npm run db:generate --workspace=@magic-beans/server",
    "db:migrate": "npm run db:migrate --workspace=@magic-beans/server",
    "db:studio": "npm run db:studio --workspace=@magic-beans/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.2"
  }
}
