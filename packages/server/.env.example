# Copy this file to ".env" (same folder) and fill in the values. ".env" is gitignored, so your
# real secrets never get committed. This ".env.example" is the safe-to-commit template.

# --- Database ---------------------------------------------------------------------------------
# Postgres connection string. Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Homebrew Postgres creates a superuser named after your macOS account with no password, so for
# local dev the user is "chrismochinski" and there is no :password segment.
DATABASE_URL=postgres://chrismochinski@localhost:5432/magic_beans

# --- Auth -------------------------------------------------------------------------------------
# Secret used to sign the session cookie (so nobody can forge a "logged in" cookie). Generate a
# fresh long random one and paste it here. Run this in your terminal to make one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVER_SESSION_SECRET=replace-me-with-a-long-random-string

# --- Server -----------------------------------------------------------------------------------
# Port the API listens on.
PORT=5000

# The client's dev URL, used for CORS (Cross-Origin Resource Sharing: the browser rule that lets
# the client at one origin talk to the API at another). Vite serves the client on 5173 by default.
CLIENT_ORIGIN=http://localhost:5173
